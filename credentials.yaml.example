# x-news-alert-v3 配置文件示例
# 复制此文件为 credentials.yaml 并填入真实值

# Twitter (twitter-cli cookie)
twitter:
  cookie: "auth_token=xxx; ct0=xxx"

# X URL (X List OAuth)
xurl:
  client_id: ""
  client_secret: ""
  access_token: ""
  refresh_token: ""

# LLM (OpenAI compatible)
llm:
  api_key: ""
  api_base: "https://api.openai.com/v1"
  model: "gpt-4o-mini"

# Discord
discord:
  bot_token: ""

# Telegram
telegram:
  bot_token: ""

# Feishu (Lark)
feishu:
  webhook: ""
  app_id: ""
  app_secret: ""
